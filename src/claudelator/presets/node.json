{
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.npm",
        "~/.cache/node",
        "~/.cache/yarn",
        "~/.cache/pnpm",
        "~/.local/share/pnpm",
        "~/.cache/node-gyp",
        "~/.cache/biome"
      ]
    },
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "registry.yarnpkg.com"
      ]
    }
  }
}
